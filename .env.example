# Your site's public URL (used for SEO, sitemaps and Open Graph)
NEXT_PUBLIC_SITE_URL=https://yourdomain.co.uk

# MongoDB
# Create a free cluster at https://www.mongodb.com/cloud/atlas, then create a
# database user (Database Access) with a username and password, and add your
# IP address (or 0.0.0.0/0 for development) under Network Access. The
# connection string can be found via Atlas's "Connect" button.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=huwlatimeraudiology_hearing
MONGODB_ANALYTICS_DB_NAME=huwlatimeraudiology_analytics

# SMTP (for booking confirmation emails)
# If left blank, confirmation emails are logged to the server console instead
# of being sent — useful for local development. Most email providers
# (Gmail, Outlook, Fastmail, transactional services like Resend, Postmark or
# SendGrid's SMTP relay) provide these details.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Huw Latimer Audiology <huw.latimer.audiologist@gmail.com>"

# Email address that receives referral notifications (your work inbox)
NOTIFY_EMAIL=

# Social media "like count" cards on the home page
# Currently the home page shows placeholder figures (see
# components/SocialCards.tsx). To show live figures, obtain API
# access/tokens from each platform and wire them up there:
#  - Facebook/Instagram: Meta Graph API access token
#  - LinkedIn: LinkedIn Marketing API access token
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
